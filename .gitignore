.env
.env.*
!.env.example

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Other IDEs
.idea/
.claude/

# System files
.DS_Store
Thumbs.db
