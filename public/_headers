# Cloudflare Pages headers. https://developers.cloudflare.com/pages/configuration/headers/

# Astro emits content-hashed asset filenames, so they can be cached forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts are stable; cache them hard and skip revalidation.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Serve the per-page raw-markdown endpoints (src/pages/[...slug].md.ts) as text
# so agents and browsers read them inline instead of downloading a file.
/*.md
  Content-Type: text/markdown; charset=utf-8

# Conservative security headers for a fully static site.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
